rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      // Read role from the users collection to avoid needing custom claims for the MVP
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function getUserDepartment() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }
    
    function isAdmin() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'super_admin');
    }

    function isExecutive() {
      return isAuthenticated() && (getUserRole() in ["super_admin", "admin", "ceo", "director"]);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || request.auth.uid == userId;
    }

    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
    
    match /report_templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /reports/{reportId} {
      // Staff can read their own reports. Admins can read all.
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      // Staff can create their own reports
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Staff can update their own drafts. Admins can update status.
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid && resource.data.status == 'draft');
      allow delete: if isSuperAdmin();
    }
    
    match /report_versions/{versionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
    }
    
    match /report_approvals/{approvalId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isSuperAdmin();
    }
    
    match /notifications/{notificationId} {
      // Users can only read and update (mark read) their own notifications
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated(); // Services triggered by users create notifications
    }
    
    match /activity_feed/{feedId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /company_locations/{locationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ==========================================
    // Phase 4: Tasks & Dashboard Rules
    // ==========================================

    match /tasks/{taskId} {
      // Admin: Full access
      // Department Head: Read tasks assigned to their department
      // Staff: Read tasks assigned directly to them, or to their department if visibility is public_department
      allow read: if isAdmin() || 
                     (isAuthenticated() && getUserRole() == 'department_head' && getUserDepartment() in resource.data.assignedTo.assignees) ||
                     (isAuthenticated() && (
                        request.auth.uid in resource.data.assignedTo.assignees ||
                        (resource.data.visibility == 'public_department' && getUserDepartment() in resource.data.assignedTo.assignees)
                     ));
                     
      // Creation and Updates: Admins and Dept Heads can manage tasks.
      // Staff can only update task status/progress if they are assigned.
      allow create: if isAdmin() || getUserRole() == 'department_head';
      allow update: if isAdmin() || 
                       getUserRole() == 'department_head' ||
                       (isAuthenticated() && request.auth.uid in resource.data.assignedTo.assignees);
      allow delete: if isSuperAdmin();
    }

    match /task_comments/{commentId} {
      allow read: if isAuthenticated(); // To be strict, should check if they can read the parent task, but for MVP it's okay.
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || request.auth.uid == resource.data.userId;
    }

    match /task_attachments/{attachmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAdmin() || request.auth.uid == resource.data.userId;
    }
    
    match /task_activity/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /kpi_scores/{scoreId} {
      // Staff can read their own scores. Admins/Dept Heads can read all.
      allow read: if isAdmin() || getUserRole() == 'department_head' || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin(); // Usually updated via Cloud Functions or Admin actions
    }

    match /department_rankings/{rankingId} {
      allow read: if isAuthenticated(); // Anyone can see rankings
      allow write: if isAdmin();
    }
    
    match /dashboard_metrics/{metricId} {
      allow read: if isAdmin() || getUserRole() == 'department_head';
      allow write: if isAdmin();
    }
    
    // ==========================================
    // Phase 5: CRM Rules
    // ==========================================

    match /customers/{customerId} {
      allow read: if isAdmin() || 
                     getUserRole() == 'customer_care' || 
                     getUserRole() == 'department_head' ||
                     (isAuthenticated() && resource.data.assignedTo == request.auth.uid);
      // Marketers and Customer Care can create
      allow create: if isAdmin() || getUserRole() == 'customer_care' || 
                       getUserRole() == 'marketer_contract' || getUserRole() == 'marketer_adhoc';
      allow update: if isAdmin() || getUserRole() == 'customer_care' || 
                       (isAuthenticated() && resource.data.assignedTo == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    match /customer_interactions/{interactionId} {
      allow read: if isAdmin() || getUserRole() == 'customer_care' || 
                     (isAuthenticated() && resource.data.staffId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.staffId == request.auth.uid;
      allow update, delete: if isSuperAdmin();
    }

    match /customer_ratings/{ratingId} {
      // Public rating links allow unauthenticated creation
      allow create: if true;
      allow read: if isAdmin() || getUserRole() == 'customer_care' || 
                     (isAuthenticated() && resource.data.staffId == request.auth.uid);
      allow update, delete: if isSuperAdmin();
    }

    match /customer_complaints/{complaintId} {
      allow read: if isAdmin() || getUserRole() == 'customer_care' || 
                     (isAuthenticated() && resource.data.assignedTo == request.auth.uid) ||
                     (isAuthenticated() && getUserRole() == 'department_head' && getUserDepartment() == resource.data.assignedDepartment);
      allow create: if isAuthenticated(); // Any staff can log a complaint on behalf of customer
      allow update: if isAdmin() || getUserRole() == 'customer_care' ||
                       (isAuthenticated() && resource.data.assignedTo == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    match /customer_notes/{noteId} {
      allow read: if isAdmin() || getUserRole() == 'customer_care' || 
                     (isAuthenticated() && resource.data.staffId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.staffId == request.auth.uid;
      allow update, delete: if isSuperAdmin();
    }

    // ==========================================
    // Phase 6: Payroll & Performance Rules
    // ==========================================

    match /employee_compensation/{compId} {
      allow read, write: if isAdmin();
    }

    match /employee_performance/{perfId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && getUserRole() == 'department_head' && resource.data.department == getUserDepartment()) ||
                     (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /payroll_periods/{periodId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /payroll_records/{recordId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && getUserRole() == 'department_head' && resource.data.department == getUserDepartment()) ||
                     (isAuthenticated() && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin();
    }
    
    match /bonuses/{bonusId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin();
    }
    
    match /commissions/{commissionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin();
    }
    
    match /deductions/{deductionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /payroll_generation_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    match /payroll_audit_logs/{auditId} {
      allow read, write: if isSuperAdmin();
    }

    // ==========================================
    // Phase 7: Executive Analytics & BI
    // ==========================================

    match /system_alerts/{alertId} {
      allow read, write: if isExecutive();
    }

    match /executive_insights/{insightId} {
      allow read, write: if isExecutive();
    }
    
    match /analytics_metadata/{metaId} {
      allow read, write: if isExecutive();
    }

    match /{document=**} {
      allow read, write: if false; // Default deny
    }
  }
}
